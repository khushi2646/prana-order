{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["es2017"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "esModuleInterop": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": ["scripts/**/*", "src/**/*"]
}
